# Copy this file to .env.local and fill in your own values.
# .env.local is already gitignored.

# Filled in automatically by contracts/scripts/deploy.js after you deploy
# KaitGateway.sol -- see contracts/DEPLOY_GUIDE.md.
NEXT_PUBLIC_GATEWAY_BASE=
NEXT_PUBLIC_GATEWAY_BASE_SEPOLIA=

# Optional. Get a free Project ID at https://cloud.reown.com to enable the
# WalletConnect option in Connect Wallet (for mobile wallets like Rainbow,
# Trust Wallet, etc). Without this, MetaMask / Coinbase Wallet still work.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
