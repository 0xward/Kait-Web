# Copy this file to .env and fill in your own values.
# .env is already in .gitignore -- never commit it, never share it.

# Your wallet's private key. With or without the 0x prefix, either works.
# This wallet must hold ETH on Base mainnet to pay for gas.
PRIVATE_KEY=

# Optional: override the default public Base RPC. Leave blank to use
# https://mainnet.base.org
BASE_RPC_URL=
